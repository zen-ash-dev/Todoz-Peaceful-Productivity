{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/**/*.svg", "/**/*.png", "/**/*.ico"]
      }
    },
    {
      "name": "fonts",
      "installMode": "prefetch",
      "resources": {
        "files": ["/fonts/*.woff2", "/fonts/*.css"]
      }
    }
  ]
}
